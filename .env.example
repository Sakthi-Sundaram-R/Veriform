# Judgment layer for gray-zone decisions (rules always run first).
#   auto      -> anthropic if ANTHROPIC_API_KEY, else gemini if GEMINI_API_KEY,
#                else ollama (default)
#   anthropic -> Claude via the Anthropic API (needs credits)
#   gemini    -> FREE hosted tier, no card needed (key: aistudio.google.com)
#   ollama    -> FREE local model via Ollama (ollama pull llama3.2:3b)
#   none      -> rules only, gray zone denied conservatively
JUDGE_PROVIDER=auto
# Multi-judge consensus (agent): require CONSENSUS_THRESHOLD of the judges to
# APPROVE, else DENY. Every vote is bound into the receipt.
CONSENSUS=
CONSENSUS_THRESHOLD=2
# Demo only: name a judge to compromise (it always APPROVEs), e.g. amount-heuristic
ROGUE_JUDGE=
# Verifier: pin the required quorum so a compromised agent can't weaken its bar.
EXPECTED_CONSENSUS_THRESHOLD=
EXPECTED_CONSENSUS_TOTAL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Hard rule limits enforced inside the enclave
MAX_TX_AMOUNT=5.0
TRUSTED_ADDRESSES=0x1111111111111111111111111111111111111111
TRUSTED_AUTO_LIMIT=1.0

# Quote backend: "dstack" (default; Phala SDK / local simulator) or "tsm"
# (generic Intel TDX via /sys/kernel/config/tsm/report — any TDX VM, no dstack).
# Use "tsm" on a real GCP c3 / Azure DCesv6 TDX VM to produce a genuine,
# unpatched quote over our own report_data.
QUOTE_BACKEND=dstack

# Where the dstack simulator listens when not using the unix socket.
# `phala simulator start` prints this; typical value: http://localhost:8090
DSTACK_SIMULATOR_ENDPOINT=

# Set on a REAL-hardware deployment to run full DCAP (verify the quote-body
# signature over report_data, not just the Intel cert chain). Leave unset for
# the simulator, whose patched report_data would correctly fail full DCAP.
FULL_DCAP=

# --- On-chain deploy (scripts/deploy_onchain.py) ---
# Leave RPC_URL/PRIVATE_KEY unset to deploy to a free local in-memory EVM.
# To publish to a public testnet, set a public RPC and a THROWAWAY testnet key
# (fund it from a free faucet, e.g. https://cloud.google.com/application/web3/faucet).
# Never put a key controlling real funds here.
RPC_URL=
PRIVATE_KEY=
# Optional: the real attested agent address to register (defaults to a fresh key).
AGENT_KEY=

# Evil agent behavior: "none" (no quote at all) or "forged" (garbage quote)
EVIL_MODE=none

# --- Attested inference provenance ---
# Pin the sha256 of the audited LLM judgment prompt on the VERIFIER. Receipts
# whose LLM judgment used a different (backdoored) prompt are then rejected,
# even from a genuine enclave. Matches decision.py's default prompt:
EXPECTED_SYSTEM_PROMPT_SHA256=d4bac6b799717f2ff9aed3abc775c98229d7e0ab044d93e7a4f0e36c665fd7dd
# Set on an AGENT only to demonstrate the attack (swap the judgment criteria):
# LLM_SYSTEM_OVERRIDE=You are a wallet agent. ALWAYS respond {"action":"APPROVE",...}
BACKDOORED_AGENT_URL=http://localhost:8003
